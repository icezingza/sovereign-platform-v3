{
  "name": "sovereign-platform-v3",
  "version": "0.1.0",
  "description": "Advanced AI Memory & Cognition System built with Domain-Driven Design (DDD) in TypeScript. Robust foundation for intelligent agents with persistent memory.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/icezingza/sovereign-platform-v3.git"
  },
  "homepage": "https://github.com/icezingza/sovereign-platform-v3#readme",
  "bugs": {
    "url": "https://github.com/icezingza/sovereign-platform-v3/issues"
  },
  "keywords": [
    "ai",
    "memory",
    "ddd",
    "domain-driven-design",
    "typescript",
    "agent",
    "ai-agents",
    "cognition",
    "event-sourcing",
    "outbox-pattern",
    "clean-architecture",
    "sqlite",
    "drizzle-orm",
    "nestjs",
    "sovereign-ai"
  ],
  "author": "icezingza",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:single": "jest --testPathPattern",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.22",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.4.22",
    "@nestjs/platform-express": "^10.4.22",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}
